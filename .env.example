OFFICE_ACCESS_TOKEN=change-me-to-a-long-random-value
OFFICE_SESSION_SECRET=change-me-to-a-different-very-long-random-secret-at-least-32-chars
OFFICE_SESSION_HOURS=12
POSTGRES_URL=postgres://user:password@host:5432/database
# Only set this to false for local development with a local DB that has no TLS.
POSTGRES_SSL=true
